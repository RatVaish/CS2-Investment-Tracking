# Database
POSTGRES_PASSWORD=your_postgres_password_here

# JWT Authentication
JWT_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App Settings
PROJECT_NAME=CS2 Investment Tracker
VERSION=2.0.0
DEBUG=False

# CORS - Add your server IP
ALLOWED_ORIGINS=["http://localhost", "http://192.168.1.232"]

# Steam API (optional)
STEAM_API_KEY=your-steam-api-key
STEAM_OPENID_REALM=http://192.168.1.232
STEAM_OPENID_RETURN_URL=http://192.168.1.232/api/v1/auth/steam/callback
